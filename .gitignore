# --- OS & IDE (系统和编辑器垃圾文件) ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.log

# --- Deploy & Secrets (部署和敏感信息) ---
.env
.env.*
!.env.example
docker-compose.override.yml
# 如果你有 SSL 证书，千万别提交
*.pem
*.key

# --- Node.js (全局) ---
node_modules/

# --- Backend (Go) ---
/back-end/vendor/
/back-end/bin/
/back-end/dist/
/back-end/*.exe
/back-end/*.test
/back-end/coverage.txt

# --- Frontend (Node.js/React) ---
/front-end/dist/
/front-end/build/
/front-end/.npm/
/front-end/*.local

# --- AI Service (Python) ---
/ai-service/__pycache__/
/ai-service/*.py[cod]
/ai-service/venv/
/ai-service/.venv/
/ai-service/env/